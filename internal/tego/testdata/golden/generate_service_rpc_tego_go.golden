			ctx, request, err = a.runPostSyncTicketEventsRequestMapping(ctx, info, request)
			if err != nil {
				err = a.mapError(err)
				receiveErr = err
				var zero TicketEvent
				yield(zero, err)
				return
			}
			if !yield(request, nil) {
				return
			}
		}
	}
	responses, err := a.service.SyncTicketEvents(ctx, requests)
	if err != nil {
		return a.mapError(err)
	}
	if responses != nil {
		for response, err := range responses {
			if err != nil {
				return a.mapError(err)
			}
			response, err = a.runPreSyncTicketEventsResponseMapping(ctx, info, response)
			if err != nil {

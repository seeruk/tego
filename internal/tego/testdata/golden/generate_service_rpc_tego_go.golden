	if receiveErr != nil {
		return nil, receiveErr
	}
	response, err = a.runPreImportTicketEventsResponseMapping(ctx, info, response)
	if err != nil {
		return nil, a.mapError(err)
	}
	responseProto, err := ImportTicketEventsResponseToProto(response)
	if err != nil {
		return nil, err
	}
	responseProto, err = a.runPostImportTicketEventsResponseMapping(ctx, info, responseProto)
	if err != nil {
		return nil, a.mapError(err)
	}
	return connect.NewResponse(responseProto), nil

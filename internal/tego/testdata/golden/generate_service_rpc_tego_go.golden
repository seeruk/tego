func (c *ticketServiceGRPCClient) SyncTicketEvents(ctx context.Context, requests iter.Seq2[TicketEvent, error]) (iter.Seq2[TicketEvent, error], error) {
	responses := func(yield func(TicketEvent, error) bool) {
		ctx, cancel := context.WithCancel(ctx)
		defer cancel()
		stream, err := c.client.SyncTicketEvents(ctx)
		if err != nil {
			var zero TicketEvent
			yield(zero, c.mapError(err))
			return
		}
		sendErr := make(chan error, 1)
		go func() {
			for request, err := range requests {
				if err != nil {
					sendErr <- err
					return
				}
				requestProto, err := TicketEventToProto(request)
				if err != nil {
					sendErr <- err
					return
				}
				if err := stream.Send(requestProto); err != nil {
					sendErr <- c.mapError(err)
					return
				}
			}
			sendErr <- c.mapError(stream.CloseSend())
		}()
		for {
			responseProto, err := stream.Recv()
			if err == io.EOF {
				if err := <-sendErr; err != nil {
					var zero TicketEvent
					yield(zero, err)
				}
				return

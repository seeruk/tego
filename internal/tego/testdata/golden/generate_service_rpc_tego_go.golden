			if err != nil {
				var zero TicketEvent
				yield(zero, c.mapError(err))
				return
			}
			response, err := TicketEventFromProto(responseProto)
			if err != nil {
				var zero TicketEvent
				yield(zero, err)
				return
			}
			if !yield(response, nil) {
				return
			}
		}
	}
	return responses, nil
}


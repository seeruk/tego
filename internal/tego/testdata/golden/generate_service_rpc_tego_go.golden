	}
	return receiveErr
}

func NewTicketServiceConnectClient(client generatedpbconnect.TicketServiceClient, opts ...tego.ConnectClientOption) TicketService {
	options := tego.NewConnectClientOptions(opts...)
	return &ticketServiceConnectClient{client: client, errorMapper: options.ErrorMapper(nil)}
}

type ticketServiceConnectClient struct {
	client      generatedpbconnect.TicketServiceClient
	errorMapper tego.ErrorMapper
}

func (c *ticketServiceConnectClient) mapError(err error) error {
	if err == nil {
		return nil
	}
	if c.errorMapper == nil {
		return err
	}
	return c.errorMapper(err)
}

func (c *ticketServiceConnectClient) FetchTicket(ctx context.Context, request GetTicketRequest) (GetTicketResponse, error) {
	var zero GetTicketResponse

func (a *TicketServiceConnectAdapter) AdaptSyncTicketEvents(ctx context.Context, stream *connect.BidiStream[generatedpb.TicketEvent, generatedpb.TicketEvent]) error {
	info := tego.RPCInfo{Service: "", Method: "SyncTicketEvents", Procedure: ""}
	var receiveErr error

func (c *ticketServiceConnectClient) SyncTicketEvents(ctx context.Context, requests iter.Seq2[TicketEvent, error]) (iter.Seq2[TicketEvent, error], error) {
	stream := c.client.SyncTicketEvents(ctx)
	responses := func(yield func(TicketEvent, error) bool) {
		sendErr := make(chan error, 1)
		go func() {
			for request, err := range requests {
				if err != nil {
					sendErr <- err
					return
				}
				requestProto2, err := TicketEventToProto(request)
				if err != nil {
					sendErr <- err
					return
				}
				requestProto := requestProto2
				if err := stream.Send(requestProto); err != nil {
					sendErr <- c.mapError(err)
					return
				}
			}
			sendErr <- c.mapError(stream.CloseRequest())
		}()
		for {
			responseProto, err := stream.Receive()
			if err != nil {
				if errors.Is(err, io.EOF) {
					break
				}
				var zero TicketEvent
				yield(zero, c.mapError(err))
				return
			}
			response, err := TicketEventFromProto(responseProto)
			if err != nil {
				var zero TicketEvent
				yield(zero, err)
				return
			}
			if !yield(response, nil) {
				return
			}
		}
		if err := <-sendErr; err != nil {
			var zero TicketEvent
			yield(zero, err)
			return
		}
		if err := stream.CloseResponse(); err != nil {
			var zero TicketEvent
			yield(zero, c.mapError(err))
		}
	}
	return responses, nil
}

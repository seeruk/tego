	responseProto, err := c.client.GetTicket(ctx, connect.NewRequest(requestProto))
	if err != nil {
		return zero, c.mapError(err)
	}
	response, err := GetTicketResponseFromProto(responseProto.Msg)
	if err != nil {
		return zero, err
	}
	return response, nil
}

func (c *ticketServiceConnectClient) WatchTicketEvents(ctx context.Context, request WatchTicketEventsRequest) (iter.Seq2[TicketEvent, error], error) {
	requestProto, err := WatchTicketEventsRequestToProto(request)
	if err != nil {
		return nil, err
	}
	responses := func(yield func(TicketEvent, error) bool) {
		ctx, cancel := context.WithCancel(ctx)
		defer cancel()
		stream, err := c.client.WatchTicketEvents(ctx, connect.NewRequest(requestProto))
		if err != nil {
			var zero TicketEvent
			yield(zero, c.mapError(err))
			return
		}
		defer stream.Close()
		for stream.Receive() {
			response, err := TicketEventFromProto(stream.Msg())
			if err != nil {
				var zero TicketEvent
				yield(zero, err)
				return
			}
			if !yield(response, nil) {
				return
			}
		}
		if err := stream.Err(); err != nil {
			var zero TicketEvent
			yield(zero, c.mapError(err))
		}
	}
	return responses, nil
}

func (c *ticketServiceConnectClient) ImportTicketEvents(ctx context.Context, requests iter.Seq2[TicketEvent, error]) (ImportTicketEventsResponse, error) {
	var zero ImportTicketEventsResponse
	stream := c.client.ImportTicketEvents(ctx)
	for request, err := range requests {
		if err != nil {
			return zero, err
		}
		requestProto, err := TicketEventToProto(request)
		if err != nil {
			return zero, err
		}
		if err := stream.Send(requestProto); err != nil {
			return zero, c.mapError(err)
		}
	}
	responseProto, err := stream.CloseAndReceive()
	if err != nil {
		return zero, c.mapError(err)
	}
	response, err := ImportTicketEventsResponseFromProto(responseProto.Msg)
	if err != nil {
		return zero, err
	}
	return response, nil
}

func (c *ticketServiceConnectClient) SyncTicketEvents(ctx context.Context, requests iter.Seq2[TicketEvent, error]) (iter.Seq2[TicketEvent, error], error) {
	responses := func(yield func(TicketEvent, error) bool) {
		ctx, cancel := context.WithCancel(ctx)
		defer cancel()
		stream := c.client.SyncTicketEvents(ctx)
		sendErr := make(chan error, 1)
		go func() {
			for request, err := range requests {
				if err != nil {
					sendErr <- err
					return
				}
				requestProto, err := TicketEventToProto(request)
				if err != nil {
					sendErr <- err
					return
				}
				if err := stream.Send(requestProto); err != nil {
					sendErr <- c.mapError(err)
					return
				}
			}
			sendErr <- c.mapError(stream.CloseRequest())
		}()
		for {
			responseProto, err := stream.Receive()
			if err != nil {
				if errors.Is(err, io.EOF) {
					break
				}
				var zero TicketEvent
				yield(zero, c.mapError(err))
				return
			}
			response, err := TicketEventFromProto(responseProto)
			if err != nil {
				var zero TicketEvent
				yield(zero, err)
				return
			}
			if !yield(response, nil) {
				return
			}
		}
		if err := <-sendErr; err != nil {
			var zero TicketEvent
			yield(zero, err)
			return
		}
		if err := stream.CloseResponse(); err != nil {
			var zero TicketEvent
			yield(zero, c.mapError(err))
		}
	}
	return responses, nil
}

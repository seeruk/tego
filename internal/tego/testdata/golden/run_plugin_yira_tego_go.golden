func ListTicketsRequestFromProto(source *yirapbv1.ListTicketsRequest) (ListTicketsRequest, error) {
	var target ListTicketsRequest
	if source == nil {
		return target, nil
	}
	target.ProjectID = source.GetProjectId()
	filter, err := TicketFilterFromProto(source.GetFilter())
	if err != nil {
		return target, err
	}
	target.Filter = filter
	target.Cursor = CursorRequestFromProto(source.GetCursor())
	return target, nil
}

func ListTicketsRequestToProto(source ListTicketsRequest) (*yirapbv1.ListTicketsRequest, error) {
	filter, err := TicketFilterToProto(source.Filter)
	if err != nil {
		return nil, err
	}
	target := yirapbv1.ListTicketsRequest_builder{
		ProjectId: &source.ProjectID,
		Filter:    filter,
		Cursor:    CursorRequestToProto(source.Cursor),
	}.Build()
	return target, nil
}

func (ltr ListTicketsRequest) ToProto() (*yirapbv1.ListTicketsRequest, error) {
	return ListTicketsRequestToProto(ltr)
}

func ListTicketsResponseFromProto(source *yirapbv1.ListTicketsResponse) (ListTicketsResponse, error) {
	var target ListTicketsResponse
	if source == nil {
		return target, nil
	}
	tickets := make([]Ticket, len(source.GetTickets()))
	for ticketsIndex, ticketsItem := range source.GetTickets() {
		ticketsItemTego, err := TicketFromProto(ticketsItem)
		if err != nil {
			return target, err
		}
		tickets[ticketsIndex] = ticketsItemTego
	}
	target.Tickets = tickets
	var ticketsByStatus map[TicketStatus][]Ticket
	if source.GetTicketsByStatus() != nil {
		ticketsByStatusEntries := source.GetTicketsByStatus().GetEntries()
		ticketsByStatus = make(map[TicketStatus][]Ticket, len(ticketsByStatusEntries))
		for _, ticketsByStatusEntry := range ticketsByStatusEntries {
			ticketsByStatusValue := make([]Ticket, len(ticketsByStatusEntry.GetValue()))
			for ticketsByStatusValueIndex, ticketsByStatusValueItem := range ticketsByStatusEntry.GetValue() {
				ticketsByStatusValueItemTego, err := TicketFromProto(ticketsByStatusValueItem)
				if err != nil {
					return target, err
				}
				ticketsByStatusValue[ticketsByStatusValueIndex] = ticketsByStatusValueItemTego
			}
			ticketsByStatus[TicketStatus(ticketsByStatusEntry.GetKey())] = ticketsByStatusValue
		}
	} else {
		ticketsByStatus = make(map[TicketStatus][]Ticket)
	}
	target.TicketsByStatus = ticketsByStatus
	target.Cursor = CursorResponseFromProto(source.GetCursor())
	return target, nil
}

func ListTicketsResponseToProto(source ListTicketsResponse) (*yirapbv1.ListTicketsResponse, error) {
	tickets := make([]*yirapbv1.Ticket, len(source.Tickets))
	for ticketsIndex, ticketsItem := range source.Tickets {
		ticketsItemProto, err := TicketToProto(ticketsItem)
		if err != nil {
			return nil, err
		}
		tickets[ticketsIndex] = ticketsItemProto
	}
	ticketsByStatusEntries := make([]*yirapbv1.TicketsByStatus_Map, 0, len(source.TicketsByStatus))
	for ticketsByStatusKey, ticketsByStatusValue := range source.TicketsByStatus {
		ticketsByStatusValueProto := make([]*yirapbv1.Ticket, len(ticketsByStatusValue))
		for ticketsByStatusValueProtoIndex, ticketsByStatusValueItem := range ticketsByStatusValue {
			ticketsByStatusValueItemProto, err := TicketToProto(ticketsByStatusValueItem)
			if err != nil {
				return nil, err
			}
			ticketsByStatusValueProto[ticketsByStatusValueProtoIndex] = ticketsByStatusValueItemProto
		}
		ticketsByStatusEntry := yirapbv1.TicketsByStatus_Map_builder{
			Key:   new(yirapbv1.TicketStatus(ticketsByStatusKey)),
			Value: ticketsByStatusValueProto,
		}.Build()
		ticketsByStatusEntries = append(ticketsByStatusEntries, ticketsByStatusEntry)
	}
	ticketsByStatus := yirapbv1.TicketsByStatus_builder{
		Entries: ticketsByStatusEntries,
	}.Build()
	target := yirapbv1.ListTicketsResponse_builder{
		Tickets:         tickets,
		TicketsByStatus: ticketsByStatus,
		Cursor:          CursorResponseToProto(source.Cursor),
	}.Build()
	return target, nil
}

func (ltr ListTicketsResponse) ToProto() (*yirapbv1.ListTicketsResponse, error) {
	return ListTicketsResponseToProto(ltr)
}


	} else {
		assignee = yirapbv1.NullablePerson_builder{
			Null: new(structpb.NullValue_NULL_VALUE),
		}.Build()
	}
	labelsValues, err := types.LabelSetToProto(source.Labels)
	if err != nil {
		return nil, err
	}
	labels := yirapbv1.Labels_builder{
		Values: labelsValues,
	}.Build()
	target := yirapbv1.TicketFilter_builder{
		Statuses: statuses,
		Assignee: assignee,
		Labels:   labels,
	}.Build()
	return target, nil
}

func (tf TicketFilter) ToProto() (*yirapbv1.TicketFilter, error) {
	return TicketFilterToProto(tf)
}

func TicketEventFromProto(source *yirapbv1.TicketEvent) TicketEvent {
	var target TicketEvent
	if source == nil {
		return target
	}
	target.ID = source.GetId()
	target.Kind = TicketEventKind(source.GetKind())
	target.Actor = PersonFromProto(source.GetActor())
	target.Note = source.GetNote()
	var payload tego.Value
	if source.GetPayload() != nil {
		payload = source.GetPayload().AsInterface()
	}
	target.Payload = payload
	var attachments tego.ListValue
	if source.GetAttachments() != nil {
		attachments = source.GetAttachments().AsSlice()
	}
	target.Attachments = attachments
	return target
}

func TicketEventToProto(source TicketEvent) (*yirapbv1.TicketEvent, error) {
	payload, err := structpb.NewValue(source.Payload)
	if err != nil {
		return nil, err
	}
	var attachments *structpb.ListValue
	if source.Attachments != nil {
		attachments2, err := structpb.NewList(source.Attachments)
		if err != nil {
			return nil, err
		}
		attachments = attachments2
	}
	target := yirapbv1.TicketEvent_builder{
		Id:          &source.ID,
		Kind:        new(yirapbv1.TicketEvent_Kind(source.Kind)),
		Actor:       PersonToProto(source.Actor),
		Note:        &source.Note,
		Payload:     payload,
		Attachments: attachments,
	}.Build()
	return target, nil
}

func (te TicketEvent) ToProto() (*yirapbv1.TicketEvent, error) {
	return TicketEventToProto(te)
}

func PersonFromProto(source *yirapbv1.Person) Person {
	var target Person
	if source == nil {
		return target
	}
	target.ID = source.GetId()
	target.DisplayName = source.GetDisplayName()
	target.Email = source.GetEmail()
	return target
}

func PersonToProto(source Person) *yirapbv1.Person {
	target := yirapbv1.Person_builder{
		Id:          &source.ID,
		DisplayName: &source.DisplayName,
		Email:       &source.Email,
	}.Build()
	return target
}

func (p Person) ToProto() *yirapbv1.Person {
	return PersonToProto(p)
}


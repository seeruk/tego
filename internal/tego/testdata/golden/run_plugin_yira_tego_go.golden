func TicketFromProto(source *yirapbv1.Ticket) (Ticket, error) {
	var target Ticket
	if source == nil {
		return target, nil
	}
	target.ID = source.GetId()
	target.ProjectID = source.GetProjectId()
	target.Title = source.GetTitle()
	target.Description = source.GetDescription()
	target.Status = TicketStatus(source.GetStatus())
	target.Priority = TicketPriority(source.GetPriority())
	var assignee *Person
	if source.GetAssignee() != nil && source.GetAssignee().WhichValue() == yirapbv1.NullablePerson_Person_case {
		assignee = new(PersonFromProto(source.GetAssignee().GetPerson()))
	}
	target.Assignee = assignee
	target.Reporter = PersonFromProto(source.GetReporter())
	var watchersSourceItems []*yirapbv1.Person
	if source.GetWatchers() != nil {
		watchersSourceItems = source.GetWatchers().GetPeople()
	}
	watchers := make([]Person, len(watchersSourceItems))
	for watchersIndex, watchersItem := range watchersSourceItems {
		watchers[watchersIndex] = PersonFromProto(watchersItem)
	}
	target.Watchers = watchers
	var labels types.Set[types.Label]
	if source.GetLabels() != nil {
		labelsValues, err := types.LabelSetFromProto(source.GetLabels().GetValues())
		if err != nil {
			return target, err
		}
		labels = labelsValues
	}
	target.Labels = labels
	var dueDate types.Date
	if source.GetDueDate() != nil {
		dueDateValue, err := types.DateFromProto(source.GetDueDate().GetValue())
		if err != nil {
			return target, err
		}
		dueDate = dueDateValue
	}
	target.DueDate = dueDate
	target.Visibility = TicketVisibility(source.GetVisibility())
	var metadata tego.Struct
	if source.GetMetadata() != nil {
		metadata = source.GetMetadata().AsMap()
	}
	target.Metadata = metadata
	switch source.WhichSource() {
	case yirapbv1.Ticket_ManualSource_case:
		target.Source = TicketManualSource{ManualSource: source.GetManualSource()}
	case yirapbv1.Ticket_IntegrationSource_case:
		target.Source = TicketIntegrationSource{IntegrationSource: source.GetIntegrationSource()}
	}
	events := make([]TicketEvent, len(source.GetEvents()))
	for eventsIndex, eventsItem := range source.GetEvents() {
		events[eventsIndex] = TicketEventFromProto(eventsItem)
	}
	target.Events = events
	return target, nil
}

func TicketToProto(source Ticket) (*yirapbv1.Ticket, error) {
	var assignee *yirapbv1.NullablePerson
	if source.Assignee != nil {
		assignee = yirapbv1.NullablePerson_builder{
			Person: PersonToProto(*source.Assignee),
		}.Build()
	} else {
		assignee = yirapbv1.NullablePerson_builder{
			Null: new(structpb.NullValue_NULL_VALUE),
		}.Build()
	}
	watchers := make([]*yirapbv1.Person, len(source.Watchers))
	for watchersIndex, watchersItem := range source.Watchers {
		watchers[watchersIndex] = PersonToProto(watchersItem)
	}
	watchers2 := yirapbv1.PersonList_builder{
		People: watchers,
	}.Build()
	labelsValues, err := types.LabelSetToProto(source.Labels)
	if err != nil {
		return nil, err
	}
	labels := yirapbv1.Labels_builder{
		Values: labelsValues,
	}.Build()
	dueDateValue, err := types.DateToProto(source.DueDate)
	if err != nil {
		return nil, err
	}
	dueDate := yirapbv1.DueDate_builder{
		Value: &dueDateValue,
	}.Build()
	var metadata *structpb.Struct
	if source.Metadata != nil {
		metadata2, err := structpb.NewStruct(source.Metadata)
		if err != nil {
			return nil, err
		}
		metadata = metadata2
	}
	var source2 *string
	var source3 *anypb.Any
	switch source4 := source.Source.(type) {
	case nil:
	case TicketManualSource:
		source2 = &source4.ManualSource
	case *TicketManualSource:
		if source4 != nil {
			source2 = &source4.ManualSource
		}
	case TicketIntegrationSource:
		source3 = source4.IntegrationSource
	case *TicketIntegrationSource:
		if source4 != nil {
			source3 = source4.IntegrationSource
		}
	default:
		return nil, errors.New("unsupported oneof implementation")
	}
	events := make([]*yirapbv1.TicketEvent, len(source.Events))
	for eventsIndex, eventsItem := range source.Events {
		eventsItemProto, err := TicketEventToProto(eventsItem)
		if err != nil {
			return nil, err
		}
		events[eventsIndex] = eventsItemProto
	}
	target := yirapbv1.Ticket_builder{
		Id:                &source.ID,
		ProjectId:         &source.ProjectID,
		Title:             &source.Title,
		Description:       &source.Description,
		Status:            new(yirapbv1.TicketStatus(source.Status)),
		Priority:          new(yirapbv1.TicketPriority(source.Priority)),
		Assignee:          assignee,
		Reporter:          PersonToProto(source.Reporter),
		Watchers:          watchers2,
		Labels:            labels,
		DueDate:           dueDate,
		Visibility:        new(yirapbv1.Ticket_Visibility(source.Visibility)),
		Metadata:          metadata,
		ManualSource:      source2,
		IntegrationSource: source3,
		Events:            events,
	}.Build()
	return target, nil
}

